@page
@model TransportCompany.Web.Pages.Employees.IndexModel
@{
    ViewData["Title"] = "Employee Dashboard";
}
<div class="container py-5">
    <div class="row g-4">

        <!-- Left column -->
        <div class="col-12 col-lg-6">
            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h3 class="mb-3">Latest Ride Requests</h3>
                <p>The latest ride requests will be shown here.</p>
                <a asp-page="/RequestOverview" class="btn btn-outline-dark">View all ride requests</a>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h3 class="mb-3">Accepted rides</h3>
                <p>Accepted rides will be shown here.</p>
                <a asp-page="/AcceptRides" class="btn btn-outline-dark">View accepted rides</a>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h3 class="mb-3">Planned rides</h3>
                <p>Planned rides will be shown here.</p>
                <a asp-page="/PlannedRides" class="btn btn-outline-dark">View planned rides</a>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h3 class="mb-3">Completed rides</h3>
                <p>Completed rides will be shown here.</p>
                <a asp-page="/CompletedRides" class="btn btn-outline-dark">View completed rides</a>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm">
                <h3 class="mb-3">Vehicle tecnicals</h3>
                <p>Planned rides will be shown here.</p>
                <a asp-page="/VehicleTecnicals" class="btn btn-outline-dark">Vehicle tecnicals</a>
            </div>
        </div>

        <!-- Right column -->
        <div class="col-12 col-lg-6">
            <div class="p-4 border rounded bg-white shadow-sm mb-4">
                <h3 class="mb-3">Add Vehicle</h3>

                <form method="post">
                    <div class="mb-3">
                        <label asp-for="Brand" class="form-label"></label>
                        <input asp-for="Brand" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="ModelName" class="form-label"></label>
                        <input asp-for="ModelName" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="BuildYear" class="form-label"></label>
                        <input asp-for="BuildYear" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="PurchasePrice" class="form-label"></label>
                        <input asp-for="PurchasePrice" class="form-control" type="number" step="0.01" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Capacity" class="form-label"></label>
                        <input asp-for="Capacity" class="form-control" type="number" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Mileage" class="form-label"></label>
                        <input asp-for="Mileage" class="form-control" type="number" />
                    </div>

                    <button type="submit" class="btn btn-dark">Add Vehicle</button>
                </form>
            </div>

            <div class="p-4 border rounded bg-white shadow-sm">
                <h3 class="mb-3">Vehicles</h3>
                <p>An overview of all vehicles and their depreciation will be shown here.</p>
                <a asp-page="/VehicleOverview" class="btn btn-outline-dark">View vehicles</a>
            </div>
        </div>

    </div>
</div>