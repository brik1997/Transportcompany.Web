@page
@model Transportbedrijf.Pages.IndexModel
@{
    ViewData["Title"] = "Home page";
}


<section class="py-5">
    <div class="container">
        <div class="bg-white rounded shadow p-5 d-flex align-items-center justify-content-between gap-5">

            <div class="w-50">
                <div class="text-center">
                <h1 class="mb-3">Betrouwbaar transport, duidelijk geregeld</h1>
                <p class="mb-4">
                        Sinds 1985 is ons transportbedrijf gevestigd in Londen.
                        Met ervaren en betrouwbare chauffeurs staan wij iedere dag klaar voor personenvervoer en transport op maat. 
                        Onze chauffeurs beschikken over grondige stratenkennis en kennen het verbonden wegennet van Londen van binnen en van buiten. 
                        Dankzij hun kennis van The Knowledge of London kunnen zij snel, veilig en efficiënt navigeren door de stad. 
                        Zo bent u verzekerd van professioneel vervoer waarop u kunt vertrouwen.
                <br /> 
                <br />
                    Wij verzorgen transportoplossingen voor zowel personenvervoer als goederenvervoer.
                    Snel, overzichtelijk en professioneel geregeld.
                </p>
                </div>
                <div class="d-flex justify-content-center gap-3">
                <a href="/Contact" class="btn btn-warning btn-lg fw-bold">Boek Taxi</a>
                <a href="/Contact" class="btn btn-warning btn-lg fw-bold">Boek Transport</a>
                </div>
            </div>

            <div class="w-50">
                <div id="homepageCarousel" class="carousel slide" data-bs-ride="carousel">
                    <div class="carousel-inner rounded">

                        <div class="carousel-item active">
                            <img src="~/image/Taxi3.jpg" class="d-block w-100" alt="Transport foto 1">
                        </div>

                        <div class="carousel-item">
                            <img src="~/image/Taxi1.jpg" class="d-block w-100" alt="Transport foto 2">
                        </div>

                        <div class="carousel-item">
                            <img src="~/image/Taxi2.jpg" class="d-block w-100" alt="Transport foto 3">
                        </div>

                    </div>

                    <button class="carousel-control-prev" type="button" data-bs-target="#homepageCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Vorige</span>
                    </button>

                    <button class="carousel-control-next" type="button" data-bs-target="#homepageCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Volgende</span>
                    </button>
                </div>
            </div>

        </div>
    </div>
</section>

